import RPi.GPIO as GPIO
import time

# Pin Configuration
SMOKE = 17
FLAME = 27
RELAY = 22

# Setup
GPIO.setmode(GPIO.BCM)
GPIO.setup(SMOKE, GPIO.IN)
GPIO.setup(FLAME, GPIO.IN)
GPIO.setup(RELAY, GPIO.OUT)

# Detect Fire
def fire_detected():
    smoke_status = GPIO.input(SMOKE)
    flame_status = GPIO.input(FLAME)

    # Logic: Smoke detected OR Flame detected
    if smoke_status == 1 or flame_status == 0:
        return True
    return False

# Alert Function
def alert():
    print("FIRE DETECTED !!")

    # Turn OFF relay (example:system shutdown)
    GPIO.output(RELAY, GPIO.LOW)

    # ⬇️ Future integration
    # send_sms()
    # make_call()
    # play_voice_alert()

    print("Emergency actions triggered!")

# Main Loop
def main():
    print("System Started... Monitoring Sensors")

    try:
        while True:
            if fire_detected():
                alert()
                break   # remove this if you want continuous monitoring

            else:
                print("No Fire...")

            time.sleep(2)

    except KeyboardInterrupt:
        print("\nSystem Stopped by User")

    finally:
        GPIO.cleanup()
        print("GPIO Cleaned ")